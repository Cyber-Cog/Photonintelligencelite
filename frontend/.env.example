# Local Vite (direct to API on :8000). Leave unset to use the Vite `/api` proxy instead.
VITE_API_BASE_URL=http://localhost:8000

# Vercel production: leave VITE_API_BASE_URL unset (or remove it) so the UI calls
# same-origin `/api/*`, which vercel.json rewrites to the Render API.
# Do NOT point the browser at Render directly — that reintroduces cold-start UX and
# cross-origin cookie friction.
