# Copy to .env for local Docker Compose use. Only deployment limits are env-overridable —
# algorithm thresholds live in analytics/config/*.yaml (see docs/architecture_decisions.md §6).
# Cloud (Neon/Render/Vercel): set the same keys in dashboards — see docs/deployment.md + render.yaml.
# Neon may give postgresql://… — the API accepts that and normalizes to postgresql+psycopg://.

DATABASE_URL=postgresql+psycopg://pic_lite:pic_lite@db:5432/pic_lite
JOB_ROOT=/srv/uploads
PIC_LITE_FREE_TIER=false
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO

# Auth (see docs/AUTH.md)
SESSION_SECRET=change-me-in-production
SESSION_TTL_DAYS=14
# Local HTTP: false → SameSite=Lax. Render (HTTPS + Vercel UI): true → SameSite=None; Secure
COOKIE_SECURE=false
PUBLIC_APP_URL=http://localhost:5173
AUTH_AUTO_VERIFY=true
# Superadmin seed (see docs/AUTH.md). Lab .local emails are accepted by auth schemas.
# PIC_SUPERADMIN_EMAIL=admin@pic.local
# PIC_SUPERADMIN_PASSWORD=admin12345
# Or: PIC_SUPERADMIN_EMAIL=admin@example.com
# PIC_SUPERADMIN_PASSWORD=choose-a-strong-password
# PIC_SUPERADMIN_NAME=Superadmin

# Optional SMTP — without it, verification/reset links are logged and returned in API responses
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
# SMTP_USE_TLS=true

# Deployment limit overrides (optional — defaults come from analytics/config/defaults.yaml)
# MAX_COMPRESSED_UPLOAD_MB=100
# MAX_DECOMPRESSED_UPLOAD_MB=250
# JOB_TIMEOUT_SEC=900
# REPORT_TTL_MINUTES=60
# Concurrent analysis workers (default 4 locally; use 1 on Render free tier — set in render.yaml).
# MAX_CONCURRENT_JOBS=4

# Frontend (Vite) — see frontend/.env.example
# On Vercel set VITE_API_BASE_URL to the Render API URL (no trailing slash).
VITE_API_BASE_URL=http://localhost:8000
